resource "aws_glue_catalog_database" "this" {
  name = "awsforge_poc_db"
}

resource "aws_glue_crawler" "this" {
  database_name = aws_glue_catalog_database.this.name
  name          = "awsforge-poc-crawler"
  role          = aws_iam_role.glue_service.arn

  s3_target {
    path = "s3://${aws_s3_bucket.this.bucket}/data/"
  }

  tags = {
    Project     = "AWSForgePOC"
    Environment = "POC"
    ManagedBy   = "AWSForge"
    CreatedBy   = "AWSForgeMCP"
  }
}
