LLM_BACKEND=ollama
ANTHROPIC_API_KEY=
OLLAMA_MODEL=mistral
OLLAMA_HOST=http://localhost:11434

AWS_REGION=ap-south-1
AWS_PROFILE=

ALERT_EMAIL=admin@example.com

TERRAFORM_BIN=/usr/bin/terraform
WORKSPACE_BASE_DIR=/opt/awsforge/workspaces
TF_APPLY_TIMEOUT_SECONDS=600

DB_PATH=/opt/awsforge/awsforge.db
LOG_FILE_DIR=/opt/awsforge/logs
LOG_LEVEL=INFO
CONFIRM_REQUIRED=true
MAX_ACTIONS_PER_PLAN=10
SESSION_HOURLY_RATE_LIMIT=5
